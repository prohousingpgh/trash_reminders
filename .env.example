# Copy to .env and fill in values below.

PGHST_BASE_URL=https://pgh.st
DATABASE_PATH=./data/app.db
APP_BASE_URL=http://localhost:5174

# --- Amazon Web Services (SES email + SNS SMS) ---
# Region where SES and SNS are enabled (us-east-1 is common)
AWS_REGION=us-east-1

# IAM access keys with ses:SendEmail and sns:Publish permissions.
# On Fly.io/EC2 you can omit these and use an IAM role instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Verified sender in SES (email address or domain must be verified first)
SES_FROM_EMAIL=reminders@yourdomain.com

# Optional: provisioned origination number for branded two-way SMS (YES/STOP replies)
# Requires SNS topic subscription to POST /webhooks/sns — see SETUP_NOTIFICATIONS.md
SNS_ORIGINATION_NUMBER=

# --- Admin ---
ADMIN_PASSWORD=choose-a-strong-password

# --- Mailchimp (optional Pro-Housing Pittsburgh newsletter) ---
# API key from Mailchimp → Account → Extras → API keys (ends with datacenter, e.g. -us19)
MAILCHIMP_API_KEY=
# Audience ID from Mailchimp → Audience → Settings → Audience name and defaults
MAILCHIMP_AUDIENCE_ID=

# Default municipality value for newsletter signups (Pittsburgh addresses)
MAILCHIMP_DEFAULT_MUNICIPALITY=City of Pittsburgh

# Merge field tags in Mailchimp — must match tags on your audience (see SETUP_MAILCHIMP.md)
MAILCHIMP_MERGE_MUNICIPALITY=MUNICIPAL
MAILCHIMP_MERGE_NEIGHBORHOOD=NEIGHBORHO
MAILCHIMP_MERGE_ZIP=ZIPCODE
